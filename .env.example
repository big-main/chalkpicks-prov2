NODE_ENV=production
PORT=3000

# Required — generate with: openssl rand -hex 64
JWT_SECRET=

# MySQL connection string
DATABASE_URL=mysql://chalkpicks:<DB_PASSWORD>@localhost:3306/chalkpicks

# AI picks (LLM) — set to any OpenAI-compatible endpoint (e.g. https://api.openai.com)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# AI pick analysis (OpenAI + Anthropic)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DAILY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email notifications (SendGrid)
SENDGRID_API_KEY=

# SMS notifications (Twilio — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

APP_URL=https://www.chalkpicks.live
